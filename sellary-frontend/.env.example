# API
# NEXT_PUBLIC_API_URL is the client-side base path for API calls (proxied by Next.js rewrite).
NEXT_PUBLIC_API_URL=/api
# NEXT_PUBLIC_API_PROXY_TARGET is the backend URL that Next.js rewrites will forward to.
# Local dev: http://127.0.0.1:8001
# Production: your internal backend URL (e.g., Railway/Fly internal address or http://backend:8001)
NEXT_PUBLIC_API_PROXY_TARGET=http://127.0.0.1:8001

# Feature flags
NEXT_PUBLIC_ENABLE_RESTAURANT=false
NEXT_PUBLIC_ENABLE_OFFLINE_MODE=false

# Health checks use the /health rewrite (same-origin), NOT the direct API_PROXY_TARGET.
# No separate health check URL config is needed.

