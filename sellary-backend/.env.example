# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sellary_db

# Security
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080
OWNER_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Bootstrap super admin
SUPER_ADMIN_USERNAME=owner
SUPER_ADMIN_EMAIL=owner@example.com
SUPER_ADMIN_PASSWORD=Pw123456
SUPER_ADMIN_FULL_NAME=App Owner

# API
API_V1_STR=/api
PROJECT_NAME=Sellary
VERSION=1.0.0

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200
