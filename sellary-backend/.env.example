# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sellary_db

# Security
# Generate with: openssl rand -hex 32
# WARNING: The default key below is unsafe. Change before deploying to production.
# NOTE (F7): SECRET_KEY also derives the encryption key for the DB-stored platform
#   settings (bot token / webhook secret / Cloudinary URL) configured in the Owner
#   panel. ROTATING SECRET_KEY invalidates every stored secret — they must be
#   re-entered in the Owner panel after a rotation.
SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
OWNER_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Environment: development | production
# Default is "production" — hard-crashes if SECRET_KEY is weak/default.
# Set to "development" for local dev to allow weak keys.
SELLARY_ENV=development

# Bootstrap super admin
SUPER_ADMIN_USERNAME=owner
SUPER_ADMIN_EMAIL=owner@example.com
SUPER_ADMIN_PASSWORD=Pw123456
SUPER_ADMIN_FULL_NAME=App Owner

# API
API_V1_STR=/api
PROJECT_NAME=Sellary
VERSION=1.0.0

# CORS
# For local dev, the defaults cover localhost:3000-3005 and 192.168.x.x.
# For production, set BACKEND_CORS_ORIGINS_RAW to a comma-separated list:
#   BACKEND_CORS_ORIGINS_RAW=https://your-frontend.example.com,https://www.example.com
BACKEND_CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Pagination
DEFAULT_PAGE_SIZE=50
MAX_PAGE_SIZE=200

# Marketplace product images (Cloudinary). Leave blank to disable image upload.
# F7: this is now an OPTIONAL FALLBACK. The Owner panel ("Настройки платформы")
#   can store an encrypted CLOUDINARY_URL in the DB, which overrides this env var.
CLOUDINARY_URL=

# Tokens are stored in localStorage — this carries inherent XSS risk.
# Consider migrating to HttpOnly cookies for production in a future release.

# Telegram Mini App marketplace bot token (from @BotFather). Leave blank to
# disable the shopper /api/shop identity path.
# F7: OPTIONAL FALLBACK — a DB value set in the Owner panel overrides this env var.
TELEGRAM_BOT_TOKEN=
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400

# Telegram bot webhook (F6 new-order notifications).
# TELEGRAM_WEBHOOK_SECRET: set to the same random string you pass to
#   setWebhook(..., secret_token=...). Empty → webhook rejects all calls (fail-closed).
#   Generate with: openssl rand -hex 24
# F7: OPTIONAL FALLBACK — a DB value set in the Owner panel overrides this env var.
TELEGRAM_WEBHOOK_SECRET=
# Bot API base URL (override for local mock / testing). No trailing slash.
TELEGRAM_API_BASE_URL=https://api.telegram.org
