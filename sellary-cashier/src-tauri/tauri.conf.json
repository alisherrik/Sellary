{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sellary Cashier",
  "version": "0.2.3",
  "identifier": "com.sellary.cashier",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Sellary Cashier",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {},
    "store": null,
    "stronghold": null,
    "updater": {
      "endpoints": [
        "https://github.com/alisherrik/Sellary/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE3RTEwMzEyOUQ0MUY5RQpSV1NlSDlRcE1SQitDcnd3R0s0R3JUQWVkdGt1MUlZb2Q5eVpJbkI5VDRDb29lQzJzUWZvdFFpcQo=",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
